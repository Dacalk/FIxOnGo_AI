rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────────────────
    // Any authenticated user can read any user document (needed for
    // mechanic search, profile viewing, shop browsing, etc.)
    // Only the document owner can write to their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Conversations collection ───────────────────────────────────────────
    // Any participant (seller or customer) may read and write the conversation doc.
    // Any authenticated user may create a new conversation.
    match /conversations/{convoId} {
      allow read, update, delete: if request.auth != null && (
        resource.data.sellerId   == request.auth.uid ||
        resource.data.customerId == request.auth.uid
      );
      allow create: if request.auth != null;

      // Sub-collection: messages
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Requests collection ────────────────────────────────────────────────
    // Any authenticated user can create/view/update requests
    // (mechanics accept, customers view their own, etc.)
    match /requests/{reqId} {
      allow read, write: if request.auth != null;
    }

    // ── Public mechanic/shop listings ─────────────────────────────────────
    // A mechanic's public shop products readable by any authenticated user
    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == shopId;
    }
  }
}
